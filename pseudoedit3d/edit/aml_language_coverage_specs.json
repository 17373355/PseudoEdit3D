{
  "version": "aml_language_coverage_specs_v1",
  "description": "Weak-label caption coverage specs for AML language audits. These are audit rules, not runtime motion-family logic.",
  "specs": [
    {
      "label": "sit_or_stand_transition",
      "issue_type": "missing_composed_family",
      "recoverability": "geometry_recoverable",
      "caption_patterns": ["\\bsits?\\s+down\\b", "\\bsitting\\b", "\\bsat\\b", "\\bstands?\\s+up\\b", "\\bgets?\\s+(back\\s+)?up\\b", "\\bsits?\\s+back\\s+down\\b"],
      "expected_families": ["SIT_DOWN_CANDIDATE", "STAND_UP_CANDIDATE", "SIT_STAND_CYCLE_CANDIDATE"],
      "substitute_families": ["SQUAT_HOLD", "LOW_BODY_REPETITION", "LOW_BODY_REPETITION_WITH_ARM_LIFT", "TORSO_HUNCHED_FORWARD"],
      "substitute_prompt_patterns": ["\\bsquats?\\b", "\\blowers?\\s+the\\s+body\\b"]
    },
    {
      "label": "lunge",
      "issue_type": "missing_composed_family",
      "recoverability": "geometry_recoverable",
      "caption_patterns": ["\\blunge\\b", "\\blunges\\b"],
      "expected_families": ["LUNGE_CANDIDATE"],
      "substitute_families": ["LEFT_LEG_KICK_FORWARD", "RIGHT_LEG_KICK_FORWARD", "LEG_FORWARD_POSE_CANDIDATE", "SQUAT_HOLD"],
      "substitute_prompt_patterns": ["\\bkicks?\\b", "\\bsquats?\\b", "\\bholds? .*leg forward\\b"]
    },
    {
      "label": "jumping_jack",
      "issue_type": "missing_composed_family",
      "recoverability": "geometry_recoverable",
      "caption_patterns": ["\\bjumping\\s+jacks?\\b"],
      "expected_families": ["BILATERAL_RHYTHMIC_COORDINATION"],
      "substitute_families": ["LEFT_HAND_RAISED_HIGH", "RIGHT_HAND_RAISED_HIGH", "VERTICAL_JUMP", "SQUAT_HOLD", "TRANSLATING_GAIT"],
      "substitute_prompt_patterns": ["\\braises? .*hand\\b", "\\bsquats?\\b", "\\bwalks?\\b"]
    },
    {
      "label": "in_place_spin",
      "issue_type": "prompt_priority_error",
      "recoverability": "geometry_recoverable",
      "caption_patterns": ["\\bspins?\\b", "\\bspinning\\b", "\\btwirls?\\b"],
      "expected_families": ["ROTATION_DOMINANT", "TURN_SEGMENT"],
      "substitute_families": ["CIRCULAR_WALK_PATH", "TRANSLATING_GAIT"],
      "substitute_prompt_patterns": ["\\bwalks? in a circular path\\b", "\\bwalks?\\b"]
    },
    {
      "label": "locomotion_prompt_priority",
      "issue_type": "prompt_priority_error",
      "recoverability": "geometry_recoverable",
      "caption_patterns": ["\\bwalk(s|ing)?\\b", "\\bjog(s|ging)?\\b", "\\brun(s|ning)?\\b", "\\bstepp?ing\\b", "\\bmoves?\\s+(forward|backward|around)\\b"],
      "negative_caption_patterns": ["\\bkick(s|ing|ed)?\\b", "\\blunge(s|ing|d)?\\b", "\\bkarate\\b", "\\bmartial\\b", "\\bfighting\\b", "\\bjump\\s+rope\\b", "\\bskipping\\s+rope\\b"],
      "expected_families": ["IN_PLACE_GAIT", "TRANSLATING_GAIT", "TRANSLATING_GAIT_SEGMENT", "CIRCULAR_WALK_PATH"],
      "substitute_families": ["LEFT_LEG_KICK_FORWARD", "RIGHT_LEG_KICK_FORWARD", "LEG_FORWARD_POSE_CANDIDATE"],
      "substitute_prompt_patterns": ["\\bkicks?\\b", "\\bholds? .*leg forward\\b"]
    },
    {
      "label": "fall_or_knees",
      "issue_type": "missing_composed_family",
      "recoverability": "geometry_recoverable",
      "caption_patterns": ["\\bfalls?\\b", "\\bon (his|her|their)?\\s*knees\\b", "\\bto (his|her|their)?\\s*knees\\b", "\\bkneels?\\b"],
      "expected_families": ["FALL_TO_KNEES_CANDIDATE", "KNEEL_CANDIDATE"],
      "substitute_families": ["SQUAT_HOLD", "LOW_BODY_REPETITION", "TORSO_HUNCHED_FORWARD", "LEFT_LEG_KICK_FORWARD", "RIGHT_LEG_KICK_FORWARD"],
      "substitute_prompt_patterns": ["\\bsquats?\\b", "\\bkicks?\\b", "\\bhunched\\b"]
    },
    {
      "label": "arm_swing_or_windmill",
      "issue_type": "missing_composed_family",
      "recoverability": "geometry_recoverable",
      "caption_patterns": ["\\bswings? .*arm\\b", "\\barm .*swings?\\b", "\\bwindmills?\\b", "\\barm .*clockwise\\b", "\\bclockwise .*arm\\b", "\\barm .*anti-?clockwise\\b", "\\banti-?clockwise .*arm\\b"],
      "expected_families": ["UNILATERAL_ARM_MIME_CANDIDATE", "ARM_SWING_CANDIDATE", "ARM_CIRCLE_CANDIDATE"],
      "substitute_families": ["LEFT_HAND_RAISED_HIGH", "RIGHT_HAND_RAISED_HIGH", "BIMANUAL_ARM_MIME_CANDIDATE"],
      "substitute_prompt_patterns": ["\\braises? .*hand\\b", "\\bmoves? both arms\\b"]
    },
    {
      "label": "hand_to_mouth_or_drinking",
