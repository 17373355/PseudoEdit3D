      "recoverability": "geometry_candidate",
      "caption_patterns": ["\\bdrinks?\\b", "\\bdrinking\\b", "\\bmouth\\b"],
      "expected_families": ["HAND_TO_MOUTH_CANDIDATE", "HAND_TO_FACE_CANDIDATE", "UNILATERAL_ARM_MIME_CANDIDATE"],
      "substitute_families": ["RIGHT_HAND_RAISED_HIGH", "LEFT_HAND_RAISED_HIGH"],
      "substitute_prompt_patterns": ["\\braises? .*hand\\b"]
    },
    {
      "label": "hand_to_head_or_phone",
      "issue_type": "object_or_intent_ambiguous",
      "recoverability": "geometry_candidate",
      "caption_patterns": ["\\bphone\\b", "\\bear\\b", "\\bhead\\b", "\\blook(s|ing)? upward\\b"],
      "expected_families": ["HAND_TO_HEAD_CANDIDATE", "HAND_NEAR_EAR_CANDIDATE", "UNILATERAL_ARM_MIME_CANDIDATE"],
      "substitute_families": ["RIGHT_HAND_RAISED_HIGH", "LEFT_HAND_RAISED_HIGH"],
      "substitute_prompt_patterns": ["\\braises? .*hand\\b"]
    },
    {
      "label": "tennis_or_ball_strike",
      "issue_type": "object_or_intent_ambiguous",
      "recoverability": "geometry_candidate",
      "caption_patterns": ["\\btennis\\b", "\\bballs?\\b", "\\bthrow(s|ing)?\\b", "\\bcatch(es|ing)?\\b"],
      "expected_families": ["OBJECT_STRIKE_OR_THROW_CANDIDATE", "UNILATERAL_ARM_MIME_CANDIDATE", "BIMANUAL_ARM_MIME_CANDIDATE"],
      "substitute_families": ["BIMANUAL_HANDS_CLOSE", "LEFT_HAND_RAISED_HIGH", "RIGHT_HAND_RAISED_HIGH", "TRANSLATING_GAIT"],
      "substitute_prompt_patterns": ["\\bwalks?\\b", "\\bjumps?\\b", "\\bsquats?\\b", "\\braises? .*hand\\b"]
    },
    {
      "label": "swim_or_prone_motion",
      "issue_type": "object_or_intent_ambiguous",
      "recoverability": "geometry_candidate",
      "caption_patterns": ["\\bswims?\\b", "\\bswimming\\b", "\\bflying around like a fly\\b"],
      "expected_families": ["SWIM_LIKE_MOTION_CANDIDATE", "PRONE_ARM_LEG_MOTION_CANDIDATE"],
      "substitute_families": ["LOW_BODY_REPETITION_WITH_ARM_LIFT", "TORSO_HUNCHED_FORWARD", "CIRCULAR_WALK_PATH", "LEFT_HAND_RAISED_HIGH"],
      "substitute_prompt_patterns": ["\\bwalks?\\b", "\\bsquats?\\b", "\\braises? .*hand\\b"]
    },
    {
      "label": "jump_rope",
      "issue_type": "missing_composed_family",
      "recoverability": "geometry_candidate",
      "caption_patterns": ["\\bjump\\s+rope\\b", "\\bskipping\\s+rope\\b"],
      "expected_families": ["JUMP_ROPE_CANDIDATE", "REPEATED_HOP_WITH_ARM_CIRCLE_CANDIDATE"],
      "substitute_families": ["VERTICAL_JUMP", "LEFT_LEG_KICK_FORWARD", "RIGHT_LEG_KICK_FORWARD", "SQUAT_HOLD", "BIMANUAL_ARM_MIME_CANDIDATE"],
      "substitute_prompt_patterns": ["\\bjumps?\\b", "\\bkicks?\\b", "\\bsquats?\\b"]
    },
    {
      "label": "combat_or_martial_arts",
      "issue_type": "missing_composed_family",
      "recoverability": "geometry_candidate",
      "caption_patterns": ["\\bkarate\\b", "\\bmartial\\b", "\\bfighting\\b", "\\bpunch(es|ing)?\\b", "\\bcombat\\b"],
      "expected_families": ["COMBAT_SEQUENCE_CANDIDATE", "PUNCH_KICK_SEQUENCE_CANDIDATE"],
      "substitute_families": ["LEFT_LEG_KICK_FORWARD", "RIGHT_LEG_KICK_FORWARD", "TURN_SEGMENT", "TRANSLATING_GAIT", "BIMANUAL_HANDS_CLOSE"],
      "substitute_prompt_patterns": ["\\bwalks?\\b", "\\bruns?\\b", "\\bturns?\\b"]
    },
    {
      "label": "cheer_or_dance",
      "issue_type": "missing_composed_family",
      "recoverability": "geometry_candidate",
      "caption_patterns": ["\\bcheer(s|ing)?\\b", "\\bdanc(es|ing)?\\b", "\\bclaps?\\b", "\\bclapping\\b"],
      "expected_families": ["BILATERAL_RHYTHMIC_GESTURE_CANDIDATE", "BIMANUAL_HANDS_CLOSE", "BIMANUAL_ARM_MIME_CANDIDATE"],
      "substitute_families": ["LEFT_HAND_RAISED_HIGH", "RIGHT_HAND_RAISED_HIGH", "LEFT_LEG_KICK_FORWARD", "RIGHT_LEG_KICK_FORWARD"],
      "substitute_prompt_patterns": ["\\bkicks?\\b", "\\braises? .*hand\\b"]
    },
    {
      "label": "acrobatics",
      "issue_type": "momask_realization_or_scale_review",
      "recoverability": "geometry_candidate",
      "caption_patterns": ["\\bcartwheel(s|ing)?\\b", "\\bbackflip(s)?\\b", "\\bhandsprings?\\b"],
      "expected_families": ["ACROBATIC_SEQUENCE_CANDIDATE", "CARTWHEEL_CANDIDATE", "INVERTED_ACROBATICS_CANDIDATE"],
      "substitute_families": ["VERTICAL_JUMP", "BALLISTIC_TRANSLATION", "TURN_SEGMENT"],
      "substitute_prompt_patterns": ["\\bjumps?\\b", "\\bturns?\\b"]
    }
  ]
